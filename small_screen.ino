namespace layout
{
    constexpr int16_t CLOCK_Y = 5;
    constexpr int16_t TEXT_Y  = SCREEN_HEIGHT - text_font::HEIGHT;
    constexpr int16_t CLOCK_X = (SCREEN_WIDTH - 5 * clock_font::WIDTH) / 2;

    void drawGlyph(uint8_t slot, const uint8_t* glyph)
    {
        display.drawBitmap(
            CLOCK_X + slot * clock_font::WIDTH, CLOCK_Y,
            glyph, clock_font::WIDTH, clock_font::HEIGHT, WHITE);
    }

    void drawTime(uint8_t hour, uint8_t minute)
    {
        drawGlyph(0, clock_font::digit(hour / 10));
        drawGlyph(1, clock_font::digit(hour % 10));
        drawGlyph(2, clock_font::Colon);
        drawGlyph(3, clock_font::digit(minute / 10));
        drawGlyph(4, clock_font::digit(minute % 10));
    }
}

namespace boot
{
    constexpr int16_t cx = 32, cy = 30;
    constexpr int16_t maxR = 26;

    // Współrzędne naszej "anomalii" (kropki)
    constexpr int16_t dotX = cx + 12;
    constexpr int16_t dotY = cy - 12;

    constexpr const char* systemLogs[] =
    {
        "[OK] Turbotoster init",     // Indeks 0
        "[OK] Mount SPIFFS",      // Indeks 1
        "[OK] I2C Bus @ 0x3C"    // Indeks 2
    };

    void display_radar()
    {
        constexpr uint8_t SWEEPS = 2;
        constexpr uint8_t STEPS = 24;

        for (uint8_t pulse = 0; pulse < SWEEPS; ++pulse) {
            for (uint8_t step = 0; step < STEPS; ++step) {
                display.clearDisplay();

                display.drawCircle(cx, cy, 8,  WHITE);
                display.drawCircle(cx, cy, 16, WHITE);
                display.drawCircle(cx, cy, 24, WHITE);
                display.drawPixel(cx, cy, WHITE);
                display.drawFastHLine(cx - maxR, cy, 2 * maxR + 1, WHITE);
                display.drawFastVLine(cx, cy - maxR, 2 * maxR + 1, WHITE);

                float a = (step * 2.0f * 3.14159265f) / STEPS;
                int16_t lx = cx + (int16_t)(cosf(a) * maxR);
                int16_t ly = cy + (int16_t)(sinf(a) * maxR);
                display.drawLine(cx, cy, lx, ly, WHITE);


                if ((pulse * STEPS + step) % 6 < 3) {
                    display.fillCircle(dotX, dotY, 2, WHITE);
                } else {
                    display.drawCircle(dotX, dotY, 1, WHITE);
                }

                display.setTextColor(WHITE);
                display.setTextSize(1);

                display.setCursor(66, 25);
                if (step % 4 > 1)
                {
                    display.print(F(""));
                }
                else
                {
                    display.print("[booting]");
                }

                int16_t prog = ((pulse * STEPS + step + 1) * (SCREEN_WIDTH - 4)) / (SWEEPS * STEPS);
                display.drawRect(2, 56, SCREEN_WIDTH - 4, 6, WHITE);
                if (prog > 2) display.fillRect(3, 57, prog - 2, 4, WHITE);

                display.display();
                delay(15); // Szybsze odświeżanie dla płynności
            }
        }


        display.clearDisplay();
        display.fillCircle(dotX, dotY, 2, WHITE);
        display.display();
        delay(400);

        int targetX = 16;
        int targetY = 38;
        display.drawLine(dotX, dotY, targetX, targetY, WHITE);
        display.display();
        delay(200);

        const char* url = "Turbotoster.dev";
        int urlLen = strlen(url);

        for (int i = 1; i <= urlLen; ++i) {
            display.clearDisplay();

            display.fillCircle(dotX, dotY, 2, WHITE);
            display.drawLine(dotX, dotY, targetX, targetY, WHITE);

            display.setCursor(targetX + 6, targetY - 3);
            for(int j = 0; j < i; ++j) {
                display.print(url[j]);
            }
            display.print("_");
            display.display();
            delay(70);
        }

        for(int i = 0; i < 4; ++i) {
            display.clearDisplay();
            display.fillCircle(dotX, dotY, 2, WHITE);
            display.drawLine(dotX, dotY, targetX, targetY, WHITE);
            display.setCursor(targetX + 6, targetY - 3);
            display.print(url);
            if (i % 2 == 0) display.print("_");
            display.display();
            delay(400);
        }
        display.clearDisplay();
        delay(200);
    }
}


void setup() {
  Serial.begin(115200);

  if(!display.begin(SSD1306_SWITCHCAPVCC, SCREEN_ADDRESS)) {
    Serial.println(F("Error while loading small screen module"));
    for(;;);
  }

  display.clearDisplay();

  display.clearDisplay();
  boot::display_radar();
  layout::drawTime(0, 0);
  display.display();

}

void loop() {
}
